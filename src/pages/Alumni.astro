// Load images
const imageFiles = import.meta.glob('/src/assets/images/**/*.{jpg,jpeg,png,webp,avif,gif}', {
  eager: true,
  import: 'default',
});

const imageMap: Record<string, any> = {};
Object.entries(imageFiles).forEach(([path, image]) => {
  const relativePath = path.replace('/src/assets/images/', '');
  imageMap[relativePath] = image;
});

const getImage = (path: string) => imageMap[path] || null;
---

<Layout fullMenu>
  <section id="wrapper">
    <header>
      <div class="inner">
        <div>
          <h2>Meet Our Alumni</h2>
          <p>
            They&apos;ve gone on to bigger things.
          </p>
        </div>
      </div>
    </header>

    <div class="wrapper team-page px-4 md:px-8 py-12">
      <div class="sticky top-0 z-40 bg-white/90 backdrop-blur-md border-b border-slate-100 shadow-sm mb-12 py-3 px-4 -mx-4 md:-mx-8">
        <div class="max-w-7xl mx-auto overflow-x-auto no-scrollbar flex gap-3 pb-1 justify-start md:justify-center items-center">
          <span class="text-xs font-bold text-slate-400 uppercase tracking-widest mr-2 shrink-0 hidden md:block">
            Jump to:
          </span>
          {alumniData.map((data, i) => (
            <a
              key={i}
              href={`#${data.year.replace(/\s+/g, '-')}`}
              class="shrink-0 px-4 py-1.5 rounded-full bg-slate-100 hover:bg-red-50 text-slate-600 hover:text-red-700 text-xs md:text-sm font-bold uppercase tracking-wide transition-colors duration-200 border-b-0 hover:border-b-0"
            >
              {data.year}
            </a>
          ))}
        </div>
      </div>

      <div class="inner max-w-7xl mx-auto">
        {alumniData.map((yearBlock, index) => (
          <div
            key={index}
            id={yearBlock.year.replace(/\s+/g, '-')}
            class="mb-24 scroll-mt-32"
          >
            <div class="flex items-center gap-6 mb-8 md:mb-12 justify-center">
              <h2 class="section-header text-xl md:text-3xl lg:text-5xl font-black tracking-tight uppercase m-0 drop-shadow-sm text-center text-slate-900">
                {yearBlock.year}
                <div class="h-1 w-12 bg-red-600 mt-2 rounded-full mx-auto shadow-[0_0_10px_rgba(220,38,38,0.5)]" />
              </h2>
            </div>

            <div class="grid grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-3 sm:gap-6">
              {yearBlock.members.map((member, memberIndex) => (
                <div key={memberIndex}>
                  <TeamMemberCard
                    name={member.name}
                    role={member.role}
                    image={getImage(member.photo)}
                    isAlumni={true}
                    linkedinUrl={member.linkedinUrl}
                  />
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
