---
// Footer.astro — static, no React needed
---

<section id="footer">
  <div class="inner">
    <h2 class="major">Get in touch</h2>
    <ul class="actions fit">
      <li>
        <a
          href="http://eepurl.com/bc5n6r"
          target="_blank"
          rel="noreferrer"
          class="button"
        >
          Join our mailing list!
        </a>
      </li>
    </ul>
    <ul class="icons" style="text-align: center;">
      <li>
        <a
          class="icon fa-instagram"
          href="https://instagram.com/nyu_acu"
          aria-label="Instagram"
          target="_blank"
          rel="noreferrer"
        >
          {' '}
        </a>
      </li>
      <li>
        <a
          class="icon fa-facebook"
          href="https://www.facebook.com/nyu.acu/"
          aria-label="Facebook"
          target="_blank"
          rel="noreferrer"
        >
          {' '}
        </a>
      </li>
      <li>
        <a
          class="icon fa-github"
          href="https://github.com/acu-nyu/"
          aria-label="GitHub"
          target="_blank"
          rel="noreferrer"
        >
          {' '}
        </a>
      </li>
    </ul>
    <p style="text-align: center;">
      Feel free to reach out to us on any of our socials!
    </p>
    <ul class="copyright">
      <li>&copy; Asian Cultural Union at NYU. All rights reserved.</li>
      <li>
        Design: <a href="http://html5up.net">HTML5 UP</a>
      </li>
    </ul>
  </div>
</section>
